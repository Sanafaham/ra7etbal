# WhatsApp Cloud API (server-only)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_TEMPLATE_LANGUAGE=en_US
OWNER_WHATSAPP_NUMBER=<E.164 format, e.g. +971501234567>
WHATSAPP_WEBHOOK_VERIFY_TOKEN=<random secret string — must match Meta dashboard webhook verify token>
